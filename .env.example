# ──────────────────────────────────────────────────────────────────────────────
# scaffold-nestjs – Environment Variables
# Copy to .env and fill in real values before running.
# ──────────────────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
ENVIRONMENT=development
PORT=8080
SERVER_URL=http://localhost
CLUSTERING=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to allow all.
CORS_ORIGIN=http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Primary (read-write)
DATABASE_URL=postgresql://postgres:password@localhost:5432/scaffold_nest
# Read replica (optional – uncomment and point to replica)
# DATABASE_REPLICA_URL=postgresql://postgres:password@replica-host:5432/scaffold_nest

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Rate limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60000     # window in ms (default: 60 000 = 1 minute)
THROTTLE_LIMIT=100     # max requests per window per IP

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters in production
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRATION=1d
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
JWT_REFRESH_EXPIRATION=7d

# ─── Mail (SMTP) ──────────────────────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
SMTP_USER=
SMTP_PASSWORD=
